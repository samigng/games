<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Grass Score</title>
  <style>
    html,body{height:100%;margin:0}
    body{display:flex;align-items:center;justify-content:center;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;margin:0;background:#f7fff0}
    #n{font-size:48px;font-weight:600;letter-spacing:0.02em;padding:24px;border-radius:12px;box-shadow:0 6px 20px rgba(0,0,0,0.08);background:white}
    #hint{position:fixed;bottom:12px;right:12px;font-size:12px;color:#666}
  </style>
</head>
<body>
  <div id="n">loading…</div>
  <div id="hint">Click number to copy</div>
  <script>
    fetch('https://api.ipify.org')
      .then(r => r.text())
      .then(t => {
        const el = document.getElementById('n')
        el.textContent = t.trim()
        el.onclick = () => {
          navigator.clipboard?.writeText(el.textContent)
            .then(() => { el.animate([{transform:'scale(1)'},{transform:'scale(0.96)'},{transform:'scale(1)'}],{duration:250}); })
            .catch(()=>{})
        }
      })
      .catch(_ => document.getElementById('n').textContent = '—')
  </script>
</body>
</html>
